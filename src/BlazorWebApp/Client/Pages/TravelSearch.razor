@page "/travelsearch"

@attribute [StreamRendering(true)]

@using Seedysoft.Libs.Travel.ViewModels
@using Seedysoft.Libs.MapRazorClassLibrary

@{
    Variant variant = Variant.Outlined;
}

<MudContainer MaxWidth="@MaxWidth.ExtraExtraLarge">

    <MudGrid Justify="@Justify.SpaceBetween">

        <MudItem xs="12" md="6">
            <MudAutocomplete @bind-Value="@travelQueryModel.Orig"
                             AutoFocus="@(!System.Diagnostics.Debugger.IsAttached)"
                             Clearable
                             DebounceInterval="450"
                             Dense
                             For="@(() => travelQueryModel.Orig)"
                             FullWidth
                             Label="Origin"
                             MaxItems="8"
                             MinCharacters="3"
                             Placeholder="Select an origin place"
                             RelativeWidth="MudBlazor.DropdownWidth.Adaptive"
                             Required
                             ResetValueOnEmptyText
                             SearchFunc="@FindPlacesAsync"
                             SelectOnActivation
                             ShowProgressIndicator
                             T="Place"
                             ToStringFunc="@(x => x.Address)"
                             Variant="@variant" />
        </MudItem>

        <MudItem xs="12" md="6">
            <MudAutocomplete @bind-Value="@travelQueryModel.Dest"
                             Clearable
                             DebounceInterval="450"
                             Dense
                             For="@(() => travelQueryModel.Dest)"
                             FullWidth
                             Label="Destination"
                             MaxItems="8"
                             MinCharacters="3"
                             Placeholder="Select a destination place"
                             RelativeWidth="MudBlazor.DropdownWidth.Adaptive"
                             Required
                             ResetValueOnEmptyText
                             SearchFunc="@FindPlacesAsync"
                             SelectOnActivation
                             ShowProgressIndicator
                             T="Place"
                             ToStringFunc="@(x => x.Address)"
                             Variant="@variant" />
        </MudItem>

        <MudItem xs="12">
            <MudButtonGroup Class="gap-4 pa-4" FullWidth Size="@Size.Medium" Variant="@variant">

                <MudButton ButtonType="@ButtonType.Button"
                           IconColor="@(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.All.Count == travelQueryModel.PetroleumProductsSelectedIds.Count ? Color.Primary : Color.Secondary)"
                           EndIcon="@Icons.Material.Filled.SelectAll"
                           IconSize="@Size.Large"
                           OnClick="@(()=> SetPetroleumProductsSelectedIds(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.All))">
                    @nameof(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.All)
                </MudButton>

                <MudButton ButtonType="@ButtonType.Button"
                           IconColor="@(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.Gasoline.Select(x => x.IdProducto).All(y => travelQueryModel.PetroleumProductsSelectedIds.Contains(y)) ? Color.Primary : Color.Secondary)"
                           EndIcon="@Icons.Material.Filled.PropaneTank"
                           IconSize="@Size.Large"
                           OnClick="@(()=> SetPetroleumProductsSelectedIds(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.Gasoline))">
                    @nameof(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.Gasoline)
                </MudButton>

                <MudButton ButtonType="@ButtonType.Button"
                           IconColor="@(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.Diesel.Select(x => x.IdProducto).All(y => travelQueryModel.PetroleumProductsSelectedIds.Contains(y)) ? Color.Primary : Color.Secondary)"
                           EndIcon="@Icons.Material.Filled.CarRepair"
                           IconSize="@Size.Large"
                           OnClick="@(()=> SetPetroleumProductsSelectedIds(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.Diesel))">
                    @nameof(Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.Diesel)
                </MudButton>

                <MudButton ButtonType="@ButtonType.Button"
                           EndIcon="@Icons.Material.Filled.Deselect"
                           IconSize="@Size.Large"
                           OnClick="@(()=> SetPetroleumProductsSelectedIds(null))">
                    None
                </MudButton>

            </MudButtonGroup>

            <MudChipSet @bind-SelectedValues="@travelQueryModel.PetroleumProductsSelectedIds"
                        CheckMark="false"
                        Color="@Color.Info"
                        SelectionMode="@SelectionMode.MultiSelection"
                        T="@Libs.GasStationPrices.Constants.ProductoPetroliferoId"
                        Variant="@Variant.Text">
                @foreach (var item in Libs.GasStationPrices.Models.Minetur.ProductoPetrolifero.All)
                {
                    <MudTooltip Text="@item.Nombre">
                        <MudChip Default="@(item.Abreviatura.StartsWith("G9", StringComparison.InvariantCultureIgnoreCase) && !item.Abreviatura.EndsWith("E10", StringComparison.InvariantCultureIgnoreCase))"
                                 Text="@item.Abreviatura.ToUpperInvariant()"
                                 Value="@item.IdProducto" />
                    </MudTooltip>
                }
            </MudChipSet>
        </MudItem>

        <MudItem xs="10">
            <MudSlider @bind-Value="@travelQueryModel.MaxDistanceInKm"
                       Immediate="false"
                       Max="50"
                       Min="1"
                       Size="@Size.Large"
                       Step="1"
                       T="int"
                       TickMarkLabels="@(Enumerable.Range(1, 50).Select(x => x == 1 || x % 5 == 0 ? $"{x}" : " ").ToArray())"
                       TickMarks />
        </MudItem>

        <MudItem xs="2">
            <MudButton ButtonType="@ButtonType.Button"
                       Class="flex-grow-all"
                       IconSize="@Size.Large"
                       OnClick="@ValidateSearchAsync"
                       Size="@Size.Large"
                       StartIcon="@Icons.Material.Filled.Search"
                       Variant="@variant">
                Search
            </MudButton>
        </MudItem>

        <MudItem xs="12">
            <MapComponent @ref="TravelMap"
                          Height="calc(80vh - 12rem)"
                          Width="100%"
                          Zoom="18">
            </MapComponent>
        </MudItem>

    </MudGrid>

</MudContainer>
