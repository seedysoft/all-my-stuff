<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <IsPublishable>False</IsPublishable>
        <RuntimeIdentifiers>linux-arm64;linux-x64;win-x64</RuntimeIdentifiers>
    </PropertyGroup>
    
    <ItemGroup>
        <None Remove="appsettings.TelegramBotSettings.Development.json" />
        <Content Include="appsettings.TelegramBotSettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <None Remove="appsettings.TelegramBotSettings.Production.json" />
    </ItemGroup>
    
    <ItemGroup Condition="'$(Configuration)' == 'Debug'">
        <Content Include="appsettings.TelegramBotSettings.Development.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <DependentUpon>appsettings.TelegramBotSettings.json</DependentUpon>
        </Content>
        <None Include="appsettings.TelegramBotSettings.Production.json">
            <CopyToOutputDirectory>Never</CopyToOutputDirectory>
            <DependentUpon>appsettings.TelegramBotSettings.json</DependentUpon>
        </None>
    </ItemGroup>
    
    <ItemGroup Condition="'$(Configuration)' == 'Release'">
        <None Include="appsettings.TelegramBotSettings.Development.json">
            <CopyToOutputDirectory>Never</CopyToOutputDirectory>
            <DependentUpon>appsettings.TelegramBotSettings.json</DependentUpon>
        </None>
        <Content Include="appsettings.TelegramBotSettings.Production.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <DependentUpon>appsettings.TelegramBotSettings.json</DependentUpon>
        </Content>
    </ItemGroup>
    
    <ItemGroup>
        <PackageReference Include="EFCore.BulkExtensions.Sqlite" Version="8.1.2" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.0.2" />
        <PackageReference Include="Telegram.Bot" Version="22.1.3" />
    </ItemGroup>
    
    <ItemGroup>
        <ProjectReference Include="..\..\Pvpc\Lib\Seedysoft.Pvpc.Lib.csproj" />
        <ProjectReference Include="..\BackgroundServices\Seedysoft.Libs.BackgroundServices.csproj" />
        <ProjectReference Include="..\Core\Seedysoft.Libs.Core.csproj" />
        <ProjectReference Include="..\Cryptography\Seedysoft.Libs.Cryptography.csproj" />
    </ItemGroup>
</Project>