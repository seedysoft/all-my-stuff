{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "TravelSettings": {
    "GeocodingSettings": {
      "CurrentImplementation": "Photon",
      "GeocodingApis": [
        {
          "Name": "Nominatim",
          "UrlFormat": "https://nominatim.openstreetmap.org/search?q={0}&format=json&limit=8"
        },
        {
          "Name": "Photon",
          "UrlFormat": "https://photon.komoot.io/api/?q={0}&limit=8"
        }
      ]
    },
    "RoutingSettings": {
      "CurrentImplementation": "Valhalla",
      "RoutingApis": [
        {
          "Name": "OSRM",
          // {origLngorigLat};{destLngdestLat}
          "UrlFormat": "http://router.project-osrm.org/trip/v1/driving/{0};{1}?roundtrip=false&source=first&destination=last&geometries=geojson"
        },
        {
          "Name": "Valhalla",
          // GET https://valhalla1.openstreetmap.de/optimized_route?json=
          // [{"lat":{{OrigLat}},"lon":{{OrigLon}}},{"lat":{{DestLat}},"lon":{{DestLon}}}]
          "UrlFormat": "https://valhalla1.openstreetmap.de/optimized_route?json={0}"
        }
      ]
    }
  }
}
